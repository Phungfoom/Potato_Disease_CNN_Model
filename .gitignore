# --- Virtual environments ---
.venv/
venv/
env/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/

# --- Tooling caches (if you add these later) ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Secrets / local env (never commit API keys) ---
.env
.env.*
!.env.example

# --- Project: large or regenerable data ---
Private/
data/
processed_data/
processed_data_v2/
*.npz

# --- Project: all generated training/eval artifacts ---
# Includes: fusion/models (*.keras), fusion/plots, fusion/field_eval,
#           image_samples/, tf_cache/, etc. (see config.OUTPUT_DIR)
outputs/

# Prevent accidental root-level model artifacts; keep models in outputs/fusion/models/
*.keras

# TensorFlow tf.data disk caches (any folder — root, old layouts, or copied paths)
# Shards look like: spud_cache_train.data-00000-of-00001 + spud_cache_train.index
/spud_cache*
spud_cache_train*
spud_cache_val*
spud_cache*.data-*
spud_cache*.index

# --- OS noise ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Google Drive sync artifacts ---
.tmp.driveupload/
.tmp.drivedownload/

# --- Editors (uncomment if you don't want IDE settings in git) ---
# .vscode/
# .idea/
